# Alloy Komodo Configuration

# Loki endpoint URL - where to send logs
# Change this to your central Loki server
LOKI_ENDPOINT=http://your-loki-server:3100/loki/api/v1/push

# Example for local LGTM stack:
# LOKI_ENDPOINT=http://lgtm:3100/loki/api/v1/push

# Example for remote server:
# LOKI_ENDPOINT=http://192.168.1.100:3100/loki/api/v1/push
